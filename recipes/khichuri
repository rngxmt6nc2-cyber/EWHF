  "stepGroups": [
    {
      "title": "Toast the Moong Dal",
      "items": [
        "Place the moong dal ({{quantity:split-yellow-moong-dal}}) in a dry Dutch oven or heavy pot over medium heat. Toast for 5 to 7 minutes, stirring often, until the dal smells nutty and turns slightly deeper yellow. Do not let it brown heavily.",
        "Transfer the toasted dal to a bowl. Rinse it under cool water until the water runs mostly clear, then drain."
      ]
    },
    {
      "title": "Rinse the Rice",
      "items": [
        "Place the basmati rice ({{quantity:basmati-rice}}) in a separate bowl. Rinse with several changes of cool water until the water runs mostly clear. Drain well."
      ]
    },
    {
      "title": "Roast the Cauliflower",
      "items": [
        "Heat the oven to 425°F.",
        "Spread the cauliflower florets on a sheet pan. Toss with 1 tablespoon of the oil and a pinch of kosher salt. Roast for 20 to 25 minutes, turning once, until browned at the edges and just tender.",
        "Hold the roasted cauliflower aside. This keeps the cauliflower from disappearing into the khichuri and gives the final dish better texture."
      ]
    },
    {
      "title": "Build the Crisp Onion Base",
      "items": [
        "In the Dutch oven, heat the remaining 1 tablespoon oil over medium heat. Add the sliced onion ({{quantity:yellow-onion}}) and cook for 12 to 15 minutes, stirring often, until deeply golden and starting to crisp at the edges.",
        "Remove about one-quarter of the onions and set them aside for garnish."
      ]
    },
    {
      "title": "Bloom the Aromatics and Spices",
      "items": [
        "To the remaining onions in the pot, add the garlic ({{quantity:garlic}}), ginger ({{quantity:fresh-ginger}}), and green chile ({{quantity:green-chile}}). Cook for 1 minute, stirring constantly.",
        "Add the bay leaves ({{quantity:bay-leaves}}), cinnamon stick ({{quantity:cinnamon-stick}}), cardamom pods ({{quantity:green-cardamom-pods}}), cloves ({{quantity:whole-cloves}}), and cumin seeds ({{quantity:cumin-seeds}}). Cook for 30 to 45 seconds, until fragrant.",
        "Add the turmeric ({{quantity:ground-turmeric}}), coriander ({{quantity:ground-coriander}}), ground cumin ({{quantity:ground-cumin}}), Kashmiri chile powder or paprika ({{quantity:kashmiri-chile-powder-or-mild-paprika}}), and black pepper ({{quantity:black-pepper}}). Stir for 30 seconds to bloom the spices in the oil and onion mixture."
      ]
    },
    {
      "title": "Cook the Khichuri",
      "items": [
        "Add the rinsed moong dal, rinsed rice, potato cubes ({{quantity:yukon-gold-potato}}), {{ingredient:water-cooking}}, and {{ingredient:kosher-salt}}. Stir well, scraping the bottom of the pot.",
        "Bring to a boil, then reduce the heat to low. Cover and simmer for 25 to 30 minutes, stirring occasionally, until the rice and dal are soft and the potato is tender.",
        "The texture should be thick, soft, and spoonable. If it tightens too much before the rice and dal are fully tender, add water 1/2 cup at a time."
      ]
    },
    {
      "title": "Finish the Dish",
      "items": [
        "Stir in the frozen peas ({{quantity:frozen-peas}}) and cook for 3 to 4 minutes, until hot and bright.",
        "Fold in about two-thirds of the roasted cauliflower. Keep the rest for topping.",
        "Remove the bay leaves, cinnamon stick, cardamom pods, and cloves as you find them.",
        "Stir in the lemon juice ({{quantity:lemon-juice}}) and chopped cilantro ({{quantity:fresh-cilantro}}). Taste and adjust salt."
      ]
    },
    {
      "title": "Serve",
      "items": [
        "Spoon the khichuri into shallow bowls. Top with the reserved roasted cauliflower, reserved crisp onions, and crushed toasted cumin seeds ({{quantity:toasted-cumin-seeds}}).",
        "The finished dish should eat like a full dinner: creamy rice and dal, tender potato, sweet peas, roasted cauliflower, warm spices, lemon brightness, and enough crisp onion on top to keep it from feeling one-note."
      ]
    }
  ]
