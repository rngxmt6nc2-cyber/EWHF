  "stepGroups": [
    {
      "title": "Char the Aromatics",
      "items": [
        "In a dry skillet or under the broiler, blister the garlic, onion, jalapeño, and poblano until softened and browned, about 5 to 7 minutes."
      ]
    },
    {
      "title": "Blend the Verde Base",
      "items": [
        "Add the charred vegetables, chopped greens, cilantro, cumin, pumpkin seeds, a pinch of salt, and 1/2 cup of the broth to a blender. Blend until smooth and bright green."
      ]
    },
    {
      "title": "Simmer the Pozole",
      "items": [
        "Pour the verde mixture into a saucepan. Add the remaining broth and the hominy. Simmer over medium-low heat for 10 to 15 minutes, stirring occasionally."
      ]
    },
    {
      "title": "Crisp the Tofu",
      "items": [
        "Heat the olive oil in a skillet over medium-high heat. Add the tofu cubes and cook until golden brown on most sides, about 7 to 8 minutes."
      ]
    },
    {
      "title": "Finish the Soup",
      "items": [
        "Stir the lime juice into the simmered verde broth, then gently fold in the crisped tofu."
      ]
    },
    {
      "title": "Serve",
      "items": [
        "Ladle into bowls and serve hot."
      ]
    }
  ]
